<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
                             https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.projectmass.controller.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>UpdateAppointmentServlet</servlet-name>
        <servlet-class>com.projectmass.controller.UpdateAppointmentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UpdateAppointmentServlet</servlet-name>
        <url-pattern>/updateAppointment</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>GetAvailableSlotsServlet</servlet-name>
        <servlet-class>com.projectmass.controller.GetAvailableSlotsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GetAvailableSlotsServlet</servlet-name>
        <url-pattern>/getAvailableSlots</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>GetDoctorsBySpecServlet</servlet-name>
        <servlet-class>com.projectmass.controller.GetDoctorsBySpecServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GetDoctorsBySpecServlet</servlet-name>
        <url-pattern>/getDoctorsBySpec</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>PatientDashboardServlet</servlet-name>
        <servlet-class>com.projectmass.controller.PatientDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PatientDashboardServlet</servlet-name>
        <url-pattern>/patientDashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DoctorDashboardServlet</servlet-name>
        <servlet-class>com.projectmass.controller.DoctorDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DoctorDashboardServlet</servlet-name>
        <url-pattern>/doctorDashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>UpdateAvailabilityServlet</servlet-name>
        <servlet-class>com.projectmass.controller.UpdateAvailabilityServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UpdateAvailabilityServlet</servlet-name>
        <url-pattern>/updateAvailability</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.projectmass.controller.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.projectmass.controller.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AppointmentServlet</servlet-name>
        <servlet-class>com.projectmass.controller.AppointmentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AppointmentServlet</servlet-name>
        <url-pattern>/bookAppointment</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>UpdateProfileServlet</servlet-name>
        <servlet-class>com.projectmass.controller.UpdateProfileServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UpdateProfileServlet</servlet-name>
        <url-pattern>/updateProfile</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>login.jsp</welcome-file>
    </welcome-file-list>
</web-app>